# ═══════════════════════════════════════════════════════
# AGENTNS — Environment Variables
# Copy to .env and fill in values before running.
# ═══════════════════════════════════════════════════════

# ── Demo Mode ───────────────────────────────────────────
# "mock" = no blockchain, no API keys needed (local demo)
# "real" = live ENS on Sepolia + real KeeperHub execution
DEMO_MODE=mock

# ── Ethereum / ENS (needed for DEMO_MODE=real) ──────────
# Sepolia testnet wallet private key (0x prefixed)
PRIVATE_KEY=
# Your wallet's public address (for swap recipient)
WALLET_ADDRESS=
# Sepolia RPC — get free key from Alchemy or Infura
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# The ENS parent name you own on Sepolia
ENS_PARENT=agentns.eth

# ── KeeperHub (needed for DEMO_MODE=real) ───────────────
# Get API key from: https://app.keeperhub.com → Settings → API Keys
# Format: kh_...
KEEPERHUB_API_KEY=

# ── LLM Providers (at least one recommended) ────────────
# Priority: Google → OpenRouter → Anthropic → Ollama → Rule-based
# All are optional — system falls back to rule-based if none set.

# Google Gemini — FREE tier: 15 RPM, 1M tokens/day
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter — many FREE models available
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Anthropic Claude — paid, required for KeeperHub MCP integration
ANTHROPIC_API_KEY=

# Ollama — local open-source models (fully free, no API key)
# Install: https://ollama.ai → run: ollama pull llama3.2
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── AXL Node Ports (set by 1_run_axl_nodes.sh) ──────────
SCOUT_AXL_PORT=9002
STRATEGY_AXL_PORT=9012
EXECUTOR_AXL_PORT=9022

# ── AXL Peer IDs (auto-filled by 3_export_keys.sh) ──────
SCOUT_PEER_ID=
STRATEGY_PEER_ID=
EXECUTOR_PEER_ID=

# ── Agent Behavior ───────────────────────────────────────
# How often Scout scans for opportunities (seconds)
SCOUT_INTERVAL=30
# Minimum confidence to dispatch a task (0.0 - 1.0)
MIN_CONFIDENCE=0.60
