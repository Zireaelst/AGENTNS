# ═══════════════════════════════════════════════════════════════
# AGENTNS — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Mode ─────────────────────────────────────────────────────
# "mock" = demo mode (no real txs), "live" = real Sepolia txs
DEMO_MODE=mock

# ─── ENS ──────────────────────────────────────────────────────
ENS_PARENT=agentns.eth
RPC_URL=https://rpc.ankr.com/eth_sepolia

# ─── Wallet (required for real ENS writes + swaps) ────────────
# Your Sepolia wallet address (0x...)
WALLET_ADDRESS=
# Private key for signing txs (ENS reputation writes). NEVER commit this!
PRIVATE_KEY=

# ─── AXL Ports ────────────────────────────────────────────────
SCOUT_AXL_PORT=9002
STRATEGY_AXL_PORT=9012
EXECUTOR_AXL_PORT=9022

# ─── AXL Peer IDs (populated by setup/3_export_keys.sh) ──────
SCOUT_PEER_ID=
STRATEGY_PEER_ID=
EXECUTOR_PEER_ID=

# ─── KeeperHub ────────────────────────────────────────────────
KEEPERHUB_API_URL=https://api.keeperhub.com
KEEPERHUB_API_KEY=

# ─── LLM (optional — fallback to rule-based if not set) ──────
ANTHROPIC_API_KEY=

# ─── Agent Loop Config ────────────────────────────────────────
# How often scout rescans for opportunities (seconds)
LOOP_INTERVAL=30
